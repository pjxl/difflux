ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...           # optional — only needed for OpenAI/GPT models
GITHUB_TOKEN=ghp_...            # optional — only needed for GitHub PR URL input and private repos
DIFFLUX_MODEL=claude-opus-4-8   # optional — overrides the default model
DIFFLUX_PROVIDER=               # optional — "anthropic" or "openai"; auto-detected from model name
